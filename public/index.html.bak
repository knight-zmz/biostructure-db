<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BioStructure DB - 专业生物结构数据库</title>
  <script src="https://cdn.jsdelivr.net/npm/molstar@latest/build/viewer/molstar.js"></script>
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/molstar@latest/build/viewer/molstar.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary-color: #0066cc;
      --secondary-color: #00a3e0;
      --accent-color: #00d9ff;
      --bg-dark: #1a1a2e;
      --bg-light: #16213e;
      --text-primary: #ffffff;
      --text-secondary: #a0a0a0;
      --success: #00ff88;
      --warning: #ffa500;
      --danger: #ff4757;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: linear-gradient(135deg, var(--bg-dark) 0%, var(--bg-light) 100%);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.6;
    }
    
    /* 头部导航 - 参考 PDB */
    header {
      background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
      padding: 0;
      box-shadow: 0 2px 20px rgba(0,0,0,0.3);
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    
    .header-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 20px;
    }
    
    .header-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 0;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    
    .logo {
      display: flex;
      align-items: center;
      gap: 15px;
      text-decoration: none;
      color: white;
    }
    
    .logo-icon {
      font-size: 32px;
      background: rgba(255,255,255,0.2);
      padding: 10px;
      border-radius: 10px;
    }
    
    .logo-text h1 {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 5px;
    }
    
    .logo-text p {
      font-size: 12px;
      opacity: 0.9;
    }
    
    nav {
      display: flex;
      gap: 5px;
    }
    
    nav a {
      color: white;
      text-decoration: none;
      padding: 12px 20px;
      border-radius: 8px;
      transition: all 0.3s;
      font-weight: 500;
    }
    
    nav a:hover {
      background: rgba(255,255,255,0.2);
    }
    
    nav a.active {
      background: rgba(255,255,255,0.3);
    }
    
    /* 搜索栏 - 参考 UniProt */
    .search-section {
      padding: 20px 0;
      background: rgba(0,0,0,0.2);
    }
    
    .search-tabs {
      display: flex;
      gap: 10px;
      margin-bottom: 15px;
    }
    
    .search-tab {
      background: rgba(255,255,255,0.1);
      border: none;
      color: white;
      padding: 10px 20px;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.3s;
      font-weight: 500;
    }
    
    .search-tab:hover,
    .search-tab.active {
      background: rgba(255,255,255,0.3);
    }
    
    .search-box {
      display: flex;
      gap: 10px;
    }
    
    .search-input {
      flex: 1;
      padding: 15px 20px;
      border: 2px solid rgba(255,255,255,0.2);
      border-radius: 8px;
      background: rgba(255,255,255,0.1);
      color: white;
      font-size: 16px;
      outline: none;
      transition: all 0.3s;
    }
    
    .search-input:focus {
      border-color: var(--accent-color);
      background: rgba(255,255,255,0.15);
    }
    
    .search-input::placeholder {
      color: var(--text-secondary);
    }
    
    .search-btn {
      background: linear-gradient(135deg, var(--accent-color), var(--secondary-color));
      border: none;
      color: var(--bg-dark);
      padding: 15px 30px;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      font-size: 16px;
    }
    
    .search-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 20px rgba(0,217,255,0.4);
    }
    
    /* 主容器 */
    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    
    /* 统计卡片 - 参考 PDB */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }
    
    .stat-card {
      background: rgba(255,255,255,0.05);
      backdrop-filter: blur(10px);
      border-radius: 15px;
      padding: 25px;
      border: 1px solid rgba(255,255,255,0.1);
      transition: all 0.3s;
    }
    
    .stat-card:hover {
      transform: translateY(-5px);
      border-color: var(--accent-color);
      box-shadow: 0 10px 30px rgba(0,217,255,0.2);
    }
    
    .stat-icon {
      font-size: 32px;
      margin-bottom: 15px;
      color: var(--accent-color);
    }
    
    .stat-number {
      font-size: 42px;
      font-weight: 700;
      background: linear-gradient(90deg, var(--accent-color), var(--success));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 5px;
    }
    
    .stat-label {
      color: var(--text-secondary);
      font-size: 14px;
    }
    
    /* 内容区域 */
    .content-grid {
      display: grid;
      grid-template-columns: 1fr 400px;
      gap: 30px;
    }
    
    @media (max-width: 1024px) {
      .content-grid {
        grid-template-columns: 1fr;
      }
    }
    
    /* 结构列表 */
    .structure-list {
      display: flex;
      flex-direction: column;
      gap: 15px;
    }
    
    .structure-item {
      background: rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 20px;
      border: 1px solid rgba(255,255,255,0.1);
      cursor: pointer;
      transition: all 0.3s;
    }
    
    .structure-item:hover {
      border-color: var(--accent-color);
      background: rgba(255,255,255,0.08);
      transform: translateX(5px);
    }
    
    .structure-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }
    
    .pdb-id {
      font-size: 24px;
      font-weight: 700;
      color: var(--accent-color);
      font-family: 'Courier New', monospace;
    }
    
    .structure-title {
      color: var(--text-secondary);
      margin-bottom: 15px;
      line-height: 1.5;
    }
    
    .structure-meta {
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
    }
    
    .tag {
      background: rgba(0,217,255,0.15);
      color: var(--accent-color);
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 500;
    }
    
    .tag.method { background: rgba(0,255,136,0.15); color: var(--success); }
    .tag.resolution { background: rgba(255,165,0,0.15); color: var(--warning); }
    
    /* 3D 查看器面板 */
    .viewer-panel {
      background: rgba(255,255,255,0.05);
      border-radius: 15px;
      padding: 20px;
      border: 1px solid rgba(255,255,255,0.1);
      position: sticky;
      top: 100px;
    }
    
    .viewer-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
      padding-bottom: 15px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    
    .viewer-title {
      font-size: 18px;
      font-weight: 600;
    }
    
    #gl {
      background: #000;
      border-radius: 10px;
      height: 400px;
      position: relative;
    }
    
    .viewer-controls {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 15px;
    }
    
    .control-btn {
      background: rgba(0,217,255,0.15);
      color: var(--accent-color);
      border: 1px solid var(--accent-color);
      padding: 10px;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.3s;
      font-weight: 500;
    }
    
    .control-btn:hover,
    .control-btn.active {
      background: var(--accent-color);
      color: var(--bg-dark);
    }
    
    /* 页脚 */
    footer {
      background: rgba(0,0,0,0.3);
      padding: 40px 20px;
      margin-top: 60px;
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    
    .footer-content {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 30px;
    }
    
    .footer-section h3 {
      color: var(--accent-color);
      margin-bottom: 15px;
      font-size: 16px;
    }
    
    .footer-section a {
      color: var(--text-secondary);
      text-decoration: none;
      display: block;
      margin-bottom: 8px;
      transition: color 0.3s;
    }
    
    .footer-section a:hover {
      color: var(--accent-color);
    }
    
    .footer-bottom {
      text-align: center;
      padding-top: 30px;
      margin-top: 30px;
      border-top: 1px solid rgba(255,255,255,0.1);
      color: var(--text-secondary);
    }
    
    /* 加载动画 */
    .loading {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 400px;
      color: var(--accent-color);
      font-size: 18px;
    }
    
    .loading::after {
      content: '';
      animation: dots 1.5s infinite;
    }
    
    @keyframes dots {
      0%, 20% { content: '.'; }
      40% { content: '..'; }
      60%, 100% { content: '...'; }
    }
    
    /* 响应式 */
    @media (max-width: 768px) {
      .header-top {
        flex-direction: column;
        gap: 15px;
      }
      
      nav {
        flex-wrap: wrap;
        justify-content: center;
      }
      
      .search-box {
        flex-direction: column;
      }
      
      .stat-number {
        font-size: 32px;
      }
    }
  </style>
</head>
<body>
  <!-- 头部导航 -->
  <header>
    <div class="header-container">
      <div class="header-top">
        <a href="/" class="logo">
          <div class="logo-icon">
            <i class="fas fa-dna"></i>
          </div>
          <div class="logo-text">
            <h1>BioStructure DB</h1>
            <p>Professional BioStructure Database</p>
          </div>
        </a>
        <nav>
          <a href="#" class="active" onclick="showSection('home')"><i class="fas fa-home"></i> 首页</a>
          <a href="#" onclick="showSection('search')"><i class="fas fa-search"></i> 搜索</a>
          <a href="#" onclick="showSection('browse')"><i class="fas fa-th"></i> 浏览</a>
          <a href="https://github.com/knight-zmz/biostructure-db" target="_blank"><i class="fab fa-github"></i> GitHub</a>
        </nav>
      </div>
      
      <!-- 搜索栏 -->
      <div class="search-section">
        <div class="search-tabs">
          <button class="search-tab active" onclick="setSearchType('structure')">结构</button>
          <button class="search-tab" onclick="setSearchType('sequence')">序列</button>
          <button class="search-tab" onclick="setSearchType('gene')">基因</button>
          <button class="search-tab" onclick="setSearchType('ligand')">配体</button>
        </div>
        <div class="search-box">
          <input type="text" class="search-input" id="searchInput" placeholder="搜索 PDB ID、结构名称、基因名..." onkeyup="if(event.key==='Enter') search(); else if(event.key==='Escape') clearSearch();">
          <button class="search-btn" onclick="search()">
            <i class="fas fa-search"></i> 搜索
          </button>
          <button class="search-btn" onclick="clearSearch()" style="background:rgba(255,255,255,0.1);color:white;">
            <i class="fas fa-times"></i> 清除
          </button>
        </div>
      </div>
    </div>
  </header>
  
  <!-- 主容器 -->
  <div class="container">
    <!-- 统计卡片 -->
    <div class="stats-grid" id="stats"></div>
    
    <!-- 内容区域 -->
    <div class="content-grid">
      <!-- 结构列表 -->
      <div>
        <h2 style="margin-bottom: 20px; font-size: 24px;">
          <i class="fas fa-cube"></i> 结构列表
        </h2>
        <div class="structure-list" id="structureList"></div>
      </div>
      
      <!-- 3D 查看器 -->
      <div class="viewer-panel">
        <div class="viewer-header">
          <div class="viewer-title">
            <i class="fas fa-cube"></i> 3D 结构查看
          </div>
          <button onclick="closeViewer()" style="background:none;border:none;color:white;cursor:pointer;font-size:20px;">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div id="gl"></div>
        <div class="viewer-controls">
          <button class="control-btn active" onclick="setStyle('cartoon', this)"><i class="fas fa-ribbon"></i> 卡通</button>
          <button class="control-btn" onclick="setStyle('stick', this)"><i class="fas fa-bars"></i> 棍状</button>
          <button class="control-btn" onclick="setStyle('sphere', this)"><i class="fas fa-circle"></i> 球棍</button>
          <button class="control-btn" onclick="setStyle('surface', this)"><i class="fas fa-globe"></i> 表面</button>
        </div>
        <div id="structureInfo" style="margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1);"></div>
      </div>
    </div>
  </div>
  
  <!-- 页脚 -->
  <footer>
    <div class="footer-content">
      <div class="footer-section">
        <h3><i class="fas fa-database"></i> 参考数据库</h3>
        <a href="https://www.rcsb.org" target="_blank"><i class="fas fa-external-link-alt"></i> PDB</a>
        <a href="https://www.uniprot.org" target="_blank"><i class="fas fa-external-link-alt"></i> UniProt</a>
        <a href="https://www.ebi.ac.uk/interpro" target="_blank"><i class="fas fa-external-link-alt"></i> Pfam</a>
        <a href="https://pubchem.ncbi.nlm.nih.gov" target="_blank"><i class="fas fa-external-link-alt"></i> PubChem</a>
      </div>
      <div class="footer-section">
        <h3><i class="fas fa-code"></i> 技术栈</h3>
        <a href="#"><i class="fab fa-node-js"></i> Node.js + Express</a>
        <a href="#"><i class="fas fa-database"></i> PostgreSQL 13</a>
        <a href="#"><i class="fab fa-github"></i> GitHub Actions</a>
        <a href="#"><i class="fas fa-server"></i> Nginx + PM2</a>
      </div>
      <div class="footer-section">
        <h3><i class="fas fa-book"></i> 文档</h3>
        <a href="https://github.com/knight-zmz/biostructure-db" target="_blank"><i class="fab fa-github"></i> GitHub</a>
        <a href="/api/stats"><i class="fas fa-plug"></i> API 文档</a>
        <a href="#"><i class="fas fa-file-alt"></i> 使用指南</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>BioStructure DB v1.0.0 | Reference: PDB + UniProt + Pfam</p>
      <p style="margin-top: 10px;">🦞 Built with OpenClaw | Deployed on Alibaba Cloud</p>
    </div>
  </footer>
  
  <script>
    let viewer = null;
    let currentPdbId = null;
    let searchType = 'structure';
    let currentStyle = 'cartoon';
    
    // 加载统计数据
    async function loadStats() {
      try {
        const res = await fetch('/api/bio/stats/detailed');
        const data = await res.json();
        
        if (data.success) {
          document.getElementById('stats').innerHTML = `
            <div class="stat-card">
              <div class="stat-icon"><i class="fas fa-cube"></i></div>
              <div class="stat-number">${data.data.totalStructures}</div>
              <div class="stat-label">蛋白质结构</div>
            </div>
            <div class="stat-card">
              <div class="stat-icon"><i class="fas fa-atom"></i></div>
              <div class="stat-number">${data.data.totalAtoms || 0}</div>
              <div class="stat-label">原子坐标</div>
            </div>
            <div class="stat-card">
              <div class="stat-icon"><i class="fas fa-vial"></i></div>
              <div class="stat-number">${data.data.methods.length}</div>
              <div class="stat-label">实验方法</div>
            </div>
            <div class="stat-card">
              <div class="stat-icon"><i class="fas fa-link"></i></div>
              <div class="stat-number">${data.data.uniqueLigands ?? '-'}</div>
              <div class="stat-label">独特配体</div>
            </div>
          `;
        }
      } catch (err) {
        console.error('加载统计失败:', err);
      }
    }
    
    // 加载结构列表
    async function loadStructures() {
      try {
        const res = await fetch('/api/structures');
        const data = await res.json();
        
        if (data.success) {
          const html = data.data.map(s => `
            <div class="structure-item" onclick="openViewer('${s.pdb_id}')">
              <div class="structure-header">
                <div class="pdb-id">${s.pdb_id}</div>
                <span class="tag resolution">${s.resolution ? s.resolution + ' Å' : 'N/A'}</span>
              </div>
              <div class="structure-title">${s.title}</div>
              <div class="structure-meta">
                <span class="tag method">${s.method || 'N/A'}</span>
                ${s.gene_name ? `<span class="tag"><i class="fas fa-dna"></i> ${s.gene_name}</span>` : ''}
                ${s.organism_scientific_name ? `<span class="tag"><i class="fas fa-virus"></i> ${s.organism_scientific_name}</span>` : ''}
              </div>
            </div>
          `).join('');
          document.getElementById('structureList').innerHTML = html;
        }
      } catch (err) {
        console.error('加载结构列表失败:', err);
      }
    }
    
    // 搜索功能
    async function search() {
      const query = document.getElementById('searchInput').value.trim();
      if (!query) {
        loadStructures();
        return;
      }
      
      // 显示加载状态
      document.getElementById('structureList').innerHTML = '<div class="loading">搜索中</div>';
      
      let url = '';
      if (searchType === 'sequence') {
        url = `/api/bio/search/sequence?sequence=${encodeURIComponent(query)}`;
      } else if (searchType === 'gene') {
        url = `/api/bio/gene/${encodeURIComponent(query)}`;
      } else if (searchType === 'ligand') {
        url = `/api/bio/search/ligand?name=${encodeURIComponent(query)}`;
      } else {
        url = `/api/bio/search/structure?q=${encodeURIComponent(query)}`;
      }
      
      try {
        const res = await fetch(url);
        const data = await res.json();
        
        let results = [];
        let resultCount = 0;
        
        if (data.success) {
          if (searchType === 'sequence') {
            // 序列搜索返回格式不同
            const exact = data.data.exact || [];
            const fuzzy = data.data.fuzzy || [];
            results = [...exact, ...fuzzy].map(s => ({
              pdb_id: s.pdb_id,
              title: `Chain ${s.chain_id} (长度: ${s.length})`,
              resolution: null,
              method: 'Sequence Match'
            }));
            resultCount = results.length;
          } else if (searchType === 'ligand') {
            results = data.data || [];
            resultCount = results.length;
          } else {
            results = data.data || [];
            resultCount = results.length;
          }
          
          if (resultCount === 0) {
            document.getElementById('structureList').innerHTML = `
              <div style="text-align:center;padding:40px;color:var(--text-secondary);">
                <i class="fas fa-search" style="font-size:48px;margin-bottom:20px;display:block;"></i>
                <p>未找到匹配结果</p>
                <p style="font-size:14px;margin-top:10px;">请尝试其他搜索词或搜索类型</p>
              </div>
            `;
            return;
          }
          
          const html = `
            <div style="margin-bottom:15px;color:var(--text-secondary);font-size:14px;">
              找到 <strong style="color:var(--accent-color)">${resultCount}</strong> 个结果
            </div>
            ${results.map(s => `
              <div class="structure-item" onclick="openViewer('${s.pdb_id}')">
                <div class="structure-header">
                  <div class="pdb-id">${s.pdb_id}</div>
                  <span class="tag resolution">${s.resolution ? s.resolution + ' Å' : 'N/A'}</span>
                </div>
                <div class="structure-title">${s.title || 'N/A'}</div>
                <div class="structure-meta">
                  <span class="tag method">${s.method || 'N/A'}</span>
                  ${s.gene_name ? `<span class="tag"><i class="fas fa-dna"></i> ${s.gene_name}</span>` : ''}
                  ${s.organism_scientific_name ? `<span class="tag"><i class="fas fa-virus"></i> ${s.organism_scientific_name}</span>` : ''}
                  ${s.ligand_name ? `<span class="tag"><i class="fas fa-link"></i> ${s.ligand_name}</span>` : ''}
                </div>
              </div>
            `).join('')}
          `;
          document.getElementById('structureList').innerHTML = html;
        } else {
          document.getElementById('structureList').innerHTML = `
            <div style="text-align:center;padding:40px;color:var(--danger);">
              <i class="fas fa-exclamation-triangle" style="font-size:48px;margin-bottom:20px;display:block;"></i>
              <p>搜索出错: ${data.error || '未知错误'}</p>
            </div>
          `;
        }
      } catch (err) {
        console.error('搜索失败:', err);
        document.getElementById('structureList').innerHTML = `
          <div style="text-align:center;padding:40px;color:var(--danger);">
            <i class="fas fa-exclamation-circle" style="font-size:48px;margin-bottom:20px;display:block;"></i>
            <p>搜索请求失败</p>
            <p style="font-size:14px;margin-top:10px;">请检查网络连接或稍后重试</p>
          </div>
        `;
      }
    }
    
    // 清除搜索
    function clearSearch() {
      document.getElementById('searchInput').value = '';
      loadStructures();
    }
    
    // 设置搜索类型
    function setSearchType(type) {
      searchType = type;
      document.querySelectorAll('.search-tab').forEach(tab => {
        tab.classList.remove('active');
        if (tab.textContent.includes(type === 'structure' ? '结构' : type === 'sequence' ? '序列' : type === 'gene' ? '基因' : '配体')) {
          tab.classList.add('active');
        }
      });
      document.getElementById('searchInput').placeholder = 
        type === 'structure' ? '搜索 PDB ID、结构名称...' :
        type === 'sequence' ? '搜索氨基酸序列...' :
        type === 'gene' ? '搜索基因名 (如：TP53, BRCA1)...' :
        '搜索配体名称...';
    }
    
    // 初始化 Molstar 查看器
    async function initMolstarViewer() {
      try {
        // 检查 Molstar 是否加载
        if (typeof molstar === 'undefined') {
          console.warn('Molstar 未加载，尝试延迟初始化...');
          setTimeout(initMolstarViewer, 1000);
          return;
        }
        
        viewer = await molstar.Viewer.create('gl', {
          layoutIsExpanded: true,
          layoutShowControls: false,
          layoutShowRemoteState: false,
          layoutShowSequence: false,
          layoutShowLog: false,
          layoutShowLeftPanel: false,
          
          viewportShowExpand: true,
          viewportShowSelectionMode: false,
          viewportShowAnimation: false,
          
          pdbProvider: 'rcsb',
          emdbProvider: 'rcsb',
        });
        
        console.log('Molstar 查看器初始化成功');
      } catch (err) {
        console.error('Molstar 初始化失败:', err);
        document.getElementById('gl').innerHTML = `
          <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:var(--text-secondary);">
            <i class="fas fa-exclamation-circle" style="font-size:48px;margin-bottom:20px;color:var(--warning);"></i>
            <p>3D 查看器加载失败</p>
            <p style="font-size:14px;margin-top:10px;">请刷新页面重试</p>
          </div>
        `;
      }
    }
    
    // 打开 3D 查看器
    async function openViewer(pdbId) {
      currentPdbId = pdbId;
      const element = document.getElementById('gl');
      element.innerHTML = '<div class="loading">加载中</div>';
      
      // 如果查看器未初始化，先初始化
      if (!viewer) {
        await initMolstarViewer();
        if (!viewer) return;
      }
      
      // 加载结构详情
      try {
        const res = await fetch(`/api/structures/${pdbId}`);
        const data = await res.json();
        
        if (data.success) {
          const s = data.data;
          document.getElementById('structureInfo').innerHTML = `
            <h4 style="margin-bottom: 10px; color: var(--accent-color);">${pdbId}</h4>
            <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 10px;">${s.title}</p>
            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
              <span class="tag">${s.method || 'N/A'}</span>
              <span class="tag">${s.resolution ? s.resolution + ' Å' : 'N/A'}</span>
              ${s.gene_name ? `<span class="tag">${s.gene_name}</span>` : ''}
            </div>
          `;
          
          // 使用 Molstar 加载 PDB 结构
          await loadStructureWithMolstar(pdbId);
        }
      } catch (err) {
        console.error('加载结构详情失败:', err);
        element.innerHTML = `
          <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:var(--danger);">
            <i class="fas fa-exclamation-triangle" style="font-size:48px;margin-bottom:20px;"></i>
            <p>加载结构失败</p>
            <p style="font-size:14px;margin-top:10px;">${err.message}</p>
          </div>
        `;
      }
    }
    
    // 使用 Molstar 加载结构
    async function loadStructureWithMolstar(pdbId) {
      try {
        // 直接从 RCSB PDB 加载
        await viewer.loadPdb(pdbId);
        applyStyle(currentStyle);
        console.log(`成功加载结构: ${pdbId}`);
      } catch (err) {
        console.error('Molstar 加载 PDB 失败，尝试从本地 API 加载:', err);
        
        // 如果 RCSB 加载失败，尝试从本地 API 获取原子数据并构建 PDB 格式
        try {
          const res = await fetch(`/api/structures/${pdbId}/atoms`);
          const data = await res.json();
          
          if (data.success && data.data.length > 0) {
            // 构建 PDB 格式数据
            let pdbData = '';
            data.data.forEach((atom, idx) => {
              const serial = String(idx + 1).padStart(5);
              const name = (atom.atom_name || 'C').padStart(4);
              const resName = (atom.residue_name || 'ALA').padStart(3);
              const chain = atom.chain_letter || 'A';
              const resSeq = String(atom.residue_num || 1).padStart(4);
              const x = parseFloat(atom.x_coord || 0).toFixed(3).padStart(8);
              const y = parseFloat(atom.y_coord || 0).toFixed(3).padStart(8);
              const z = parseFloat(atom.z_coord || 0).toFixed(3).padStart(8);
              const element = (atom.element || 'C').padStart(2);
              
              pdbData += `ATOM  ${serial} ${name} ${resName} ${chain}${resSeq}    ${x}${y}${z}  1.00  0.00           ${element}\n`;
            });
            pdbData += 'END\n';
            
            // 使用 Molstar 加载 PDB 数据
            await viewer.loadStructureFromData(pdbData, 'pdb', false);
            applyStyle(currentStyle);
            console.log(`从本地 API 加载结构成功: ${pdbId}`);
          } else {
            throw new Error('没有原子坐标数据');
          }
        } catch (localErr) {
          console.error('本地加载也失败:', localErr);
          document.getElementById('gl').innerHTML = `
            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:var(--warning);">
              <i class="fas fa-cube" style="font-size:48px;margin-bottom:20px;"></i>
              <p>暂无 3D 数据</p>
              <p style="font-size:14px;margin-top:10px;">该结构暂无原子坐标</p>
            </div>
          `;
        }
      }
    }
    
    // 应用显示样式
    function applyStyle(style) {
      if (!viewer) return;
      
      currentStyle = style;
      
      // Molstar 样式映射
      const styleMap = {
        cartoon: 'cartoon',
        stick: 'ball-and-stick',
        sphere: 'spacefill',
        surface: 'molecular-surface'
      };
      
      try {
        // 获取当前结构并应用样式
        const plugin = viewer.plugin;
        if (plugin && plugin.managers) {
          // 使用 Molstar 的表示管理器
          const structures = plugin.managers.structure.hierarchy.current.structures;
          if (structures && structures.length > 0) {
            const structure = structures[0];
            const repr = structure.representations[0];
            if (repr) {
              // 更新表示类型
              plugin.managers.structure.component.updateRepresentationsTheme(structure.components, {
                type: styleMap[style] || 'cartoon',
                color: 'sequence-id'
              });
            }
          }
        }
      } catch (err) {
        console.warn('应用样式失败，使用默认样式:', err);
      }
    }
    
    // 切换显示样式
    function setStyle(style, btn) {
      document.querySelectorAll('.control-btn').forEach(b => b.classList.remove('active'));
      if (btn) btn.classList.add('active');
      
      currentStyle = style;
      applyStyle(style);
    }
    
    // 关闭查看器
    function closeViewer() {
      if (viewer) {
        try {
          viewer.clear();
        } catch (err) {
          console.warn('关闭查看器时出错:', err);
        }
      }
      document.getElementById('structureInfo').innerHTML = '';
      document.getElementById('gl').innerHTML = '';
    }
    
    // 切换板块
    function showSection(section) {
      // 可以在这里添加不同板块的逻辑
      console.log('切换到:', section);
    }
    
    // 初始化
    document.addEventListener('DOMContentLoaded', async () => {
      await loadStats();
      await loadStructures();
      await initMolstarViewer();
    });
    
    // 页面加载完成后立即执行
    loadStats();
    loadStructures();
  </script>
</body>
</html>
