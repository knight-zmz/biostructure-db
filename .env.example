# BioStructure DB 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置 ====================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=myapp
DB_USER=myapp_user
DB_PASSWORD=your_password_here

# ==================== Redis 配置 ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ==================== 应用配置 ====================
NODE_ENV=production
PORT=3000

# ==================== 日志配置 ====================
# PM2 日志路径 (可选，默认 ~/.pm2/logs/)
# PM2_ERROR_LOG=/home/admin/.pm2/logs/myapp-error.log
# PM2_OUT_LOG=/home/admin/.pm2/logs/myapp-out.log
