{
  "name": "biostructure-db",
  "version": "1.0.0",
  "description": "Professional BioStructure Database - Reference PDB + UniProt + Pfam",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest",
    "build": "echo 'Build completed'",
    "lint": "eslint .",
    "format": "prettier --write '**/*.js'",
    "db:migrate": "psql -U myapp_user -d myapp -f schema_v2.sql",
    "db:backup": "pg_dump -U myapp_user myapp > backups/backup-$(date +%Y%m%d).sql",
    "db:restore": "psql -U myapp_user myapp < backups/backup.sql",
    "import:samples": "curl -X POST http://localhost/api/import-samples",
    "deploy": "pm2 restart myapp && pm2 save"
  },
  "keywords": [
    "bioinformatics",
    "protein",
    "structure",
    "database",
    "pdb",
    "uniprot",
    "pfam"
  ],
  "author": "OpenClaw Bio Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/biostructure-db.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/biostructure-db/issues"
  },
  "homepage": "https://github.com/your-username/biostructure-db#readme",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.4.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "app.js",
    "bioapi.js",
    "pdb-parser.js",
    "mcp-server.js",
    "public/",
    "schema_v2.sql",
    "README.md"
  ],
  "bin": {
    "biostructure-db": "./bin/cli.js"
  }
}
